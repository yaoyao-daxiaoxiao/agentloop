# API Configuration
# This supports any OpenAI-compatible API

# OpenAI (Default)
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL=gpt-4o

# DeepSeek (Recommended for China users)
# Get your key from https://platform.deepseek.com/api_keys
OPENAI_API_KEY=sk-your-deepseek-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
MODEL=deepseek-chat

# Other compatible APIs:
# - https://api.openai-hub.com/v1
# - https://api.openai-proxy.com/v1
# - https://api.closeai-asia.com/v1
